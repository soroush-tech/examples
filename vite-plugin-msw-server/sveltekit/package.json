{
  "name": "@vite-plugin-msw-server/sveltekit-demo",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "SvelteKit demo for @soroush.tech/vite-plugin-msw-server — server-side fetches resolved against msw mocks during `vite dev` (SSR), with a +error.svelte error state.",
  "scripts": {
    "dev": "vite dev",
