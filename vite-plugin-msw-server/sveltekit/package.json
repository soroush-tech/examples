    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@soroush.tech/vite-plugin-msw-server": "^0.2.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "msw": "^2.14.6",
    "svelte": "^5.42.0",
    "svelte-check": "^4.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
